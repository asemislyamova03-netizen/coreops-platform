# Application
APP_NAME=CoreOps Platform
APP_ENV=staging
DEBUG=false
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+psycopg://coreops:coreops@localhost:5432/coreops
# Consulting staging write-import ONLY (never reuse DATABASE_URL for writes):
# CONSULTING_STAGING_DATABASE_URL=postgresql+psycopg://coreops:coreops@localhost:5432/coreops_staging_0013

# Security (Phase 1+)
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage
STORAGE_PATH=./storage
SEED_ON_STARTUP=false

# Public inbound leads
PUBLIC_LEADS_ENABLED=false
PUBLIC_LEADS_TARGET_TENANT_ID=
PUBLIC_LEADS_PIPELINE_ID=
PUBLIC_LEADS_STAGE_ID=
PUBLIC_LEADS_CREATED_BY_USER_ID=
PUBLIC_LEADS_ALLOWED_ORIGINS=
PUBLIC_LEADS_TELEGRAM_BOT_TOKEN=
PUBLIC_LEADS_TELEGRAM_CHAT_ID=
